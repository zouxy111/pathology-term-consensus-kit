{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pathology terminology project config",
  "type": "object",
  "required": ["project", "inputs", "field_mapping", "companies", "target_filter", "outputs"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "subspecialty"],
      "properties": {
        "name": { "type": "string" },
        "subspecialty": { "type": "string" }
      }
    },
    "inputs": {
      "type": "object",
      "required": ["term_catalog", "reports"],
      "properties": {
        "term_catalog": { "type": "string" },
        "reports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "expected_rows": { "type": ["integer", "null"] },
              "label": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "field_mapping": {
      "type": "object",
      "required": ["company_field", "report_text_field"],
      "properties": {
        "company_field": { "type": "string" },
        "report_text_field": { "type": "string" },
        "context_fields": { "type": "array", "items": { "type": "string" } }
      }
    },
    "companies": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "target_filter": {
      "type": "object",
      "required": ["include_terms", "exclude_terms"],
      "properties": {
        "include_terms": { "type": "array", "items": { "type": "string" } },
        "exclude_terms": { "type": "array", "items": { "type": "string" } },
        "text_split_pattern": { "type": "string" },
        "allow_empty_include_terms": { "type": "boolean" }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["output_dir"],
      "properties": {
        "output_dir": { "type": "string" }
      }
    }
  }
}

